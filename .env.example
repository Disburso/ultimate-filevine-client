# Filevine v2 (US) — per-tenant credentials.
# Copy to .env (gitignored) for local exploration via bin/console.
# In production each TENANT supplies its own set of these values; the gem holds
# no global credentials.

# OAuth client + Personal Access Token (mint a bearer via identity.filevine.com)
FILEVINE_CLIENT_ID=
FILEVINE_CLIENT_SECRET=
FILEVINE_PAT=

# Optional — resolved via POST /fv-app/v2/utils/GetUserOrgsWithToken when omitted.
FILEVINE_ORG_ID=
FILEVINE_USER_ID=

# Region/cell: us (default) | ca | cjis
FILEVINE_REGION=us

# --- Recording pass (spec/recording) -----------------------------------------
# Unset for the normal suite (offline, replays committed cassettes). Set to record
# real interactions from a SANDBOX org (synthetic data only) into cassettes:
#   FILEVINE_RECORD=1     record only the cassettes that don't exist yet
#   FILEVINE_RECORD=all   re-record (overwrite) existing cassettes
# Then: `bundle exec rake record:sandbox`. Requires the FILEVINE_* creds above.
FILEVINE_RECORD=
